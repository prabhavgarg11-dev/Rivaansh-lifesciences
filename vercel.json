{
  "version": 2,
  "name": "rivaansh-frontend",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [ 
    {
      "source": "/api/(.*)",
      "destination": "https://rivaansh-lifesciences.onrender.com/api/$1"
    },
    {
      "source": "/(?!frontend/|api/)(.*)",
      "destination": "/frontend/$1"
    }
  ]
} 