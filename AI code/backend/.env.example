# ─── Rivaansh Lifesciences — Environment Variables Template ──────────────────
# 1. Copy this file → rename the copy to  .env
# 2. Fill in your real values
# 3. NEVER commit .env to version control

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/rivaansh?retryWrites=true&w=majority
ADMIN_EMAIL=admin@rivaansh.com
ADMIN_PASSWORD=Admin@123
ADMIN_SECRET=change_this_secret
JWT_SECRET=change_this_jwt_secret
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://rivaansh-lifesciences.onrender.com,https://rivaansh-lifesciences.vercel.app

# ── AI Configuration (Gemini) ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Payment Integration (Razorpay) ───────────────────────────────────────────
RAZORPAY_KEY=your_razorpay_key_here
RAZORPAY_SECRET=your_razorpay_secret_here
