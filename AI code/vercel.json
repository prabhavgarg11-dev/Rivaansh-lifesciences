{
  "version": 2,
  "framework": null,
  "public": true,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://rivaansh-lifesciences.onrender.com/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://rivaansh-lifesciences.onrender.com/uploads/:path*" },
    { "source": "/images/(.*)", "destination": "/frontend/images/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}